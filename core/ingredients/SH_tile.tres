[gd_resource type="Shader" format=3 uid="uid://bm0d7ekqd6hnk"]

[resource]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_never, depth_test_disabled, cull_disabled, diffuse_lambert, specular_schlick_ggx;

uniform vec4 Color : source_color = vec4(1.000000, 1.000000, 1.000000, 1.000000);
uniform float EmissiveStrength = 1.0;



void fragment() {
// Input:2
	vec2 n_out2p0 = UV;


// VectorOp:3
	vec3 n_in3p1 = vec3(0.50000, 0.50000, 0.50000);
	vec3 n_out3p0 = vec3(n_out2p0, 0.0) - n_in3p1;


// VectorFunc:4
	vec3 n_out4p0 = abs(n_out3p0);


// VectorDecompose:5
	float n_out5p0 = n_out4p0.x;
	float n_out5p1 = n_out4p0.y;
	float n_out5p2 = n_out4p0.z;


// FloatOp:6
	float n_in6p1 = 0.48000;
	float n_out6p0 = step(n_out5p0, n_in6p1);


// FloatOp:7
	float n_in7p1 = 0.48000;
	float n_out7p0 = step(n_out5p1, n_in7p1);


// FloatOp:8
	float n_out8p0 = n_out6p0 * n_out7p0;


// VectorFunc:9
	vec3 n_out9p0 = vec3(1.0) - vec3(n_out8p0);


// ColorParameter:10
	vec4 n_out10p0 = Color;


// FloatParameter:12
	float n_out12p0 = EmissiveStrength;


// VectorOp:11
	vec3 n_out11p0 = vec3(n_out10p0.xyz) * vec3(n_out12p0);


// Output:0
	ALPHA = n_out9p0.x > 0.5 ? 0.99 : 0.0;
	EMISSION = n_out11p0;


}
"
